# ── Cloudflare ────────────────────────────────────────────────────────────────
# Token needs Zone:DNS:Edit — create at dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_token_here

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
CERTBOT_EMAIL=you@example.com
CERT_NAME=mysite
CERTBOT_DOMAINS="example.com *.example.com"

# ── Remote server ─────────────────────────────────────────────────────────────
SSH_HOST=myserver
CPANEL_DOMAINS="example.com"
VERIFY_DOMAINS="example.com www.example.com"

# ── VPS deployment (optional) ─────────────────────────────────────────────────
# SSH alias for the VPS. If set, cert is deployed to VPS_CERT_DIR after renewal
# and the Caddy container is reloaded automatically.
VPS_HOST=
VPS_CERT_DIR=/opt/apps/caddy/certs
